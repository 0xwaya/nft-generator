{
  "name": "wayalabs_nft_generator",
  "version": "1.1.1",
  "description": "Wayalabs Art Engine is a tool used to create multiple different instances of artworks based on provided layers by wayalabs artists.",
  "main": "index.js",
  "bin": "index.js",
  "pkg": {
    "assets": [
      "layers/**/*",
      "node_modules/**/*",
      "src/**/*"
    ]
  },
  "scripts": {
    "build": "node index.js",
    "generate": "node index.js",
    "rarity": "node utils/rarity.js",
    "preview": "node utils/preview.js",
    "pixelate": "node utils/pixelate.js",
    "update_info": "node utils/update_info.js",
    "generate_gif": "node utils/generate_gif.js",
    "preview_gif": "node utils/preview_gif.js",
    "generate_metadata": "node utils/generate_metadata.js"
  },
  "author": "@0xwaya",
  "license": "MIT",
  "dependencies": {
    "canvas": "^2.11.2",
    "gif-encoder-2": "^1.0.5",
    "giffer": "^2.0.16",
    "sha1": "^1.1.1"
  }
}
